rule first_step:
    input: "input-files/{sample}.txt"
    output: "results/output_{sample}.txt"
    shell: "cat {input} > {output}"


rule upper_case:
    input: "results/output_{sample}.txt"
    output: "results/uppercase_output_{sample}.txt"
    shell: "tr '[:lower:]' '[:upper:]' < {input} > {output}"

